  <script>
    let records = JSON.parse(document.getElementById("records-data").textContent);
    const rows = document.getElementById("rows");
    const empty = document.getElementById("empty");
    const summary = document.getElementById("summary");
    const search = document.getElementById("search");
    const project = document.getElementById("project");
    const iteration = document.getElementById("iteration");
    const statusFilter = document.getElementById("statusFilter");
    const reset = document.getElementById("reset");
    const pageTotal = document.getElementById("pageTotal");
    const pageSize = document.getElementById("pageSize");
    const pager = document.getElementById("pager");
    const gitlabSettings = document.getElementById("gitlabSettings");
    const gitlabModal = document.getElementById("gitlabModal");
    const closeGitlabModal = document.getElementById("closeGitlabModal");
    const gitlabUrl = document.getElementById("gitlabUrl");
    const gitlabToken = document.getElementById("gitlabToken");
    const gitlabTarget = document.getElementById("gitlabTarget");
    const gitlabSavedToken = document.getElementById("gitlabSavedToken");
    const gitlabStatus = document.getElementById("gitlabStatus");
    const testGitlab = document.getElementById("testGitlab");
    const saveGitlab = document.getElementById("saveGitlab");
    const bulkMrButton = document.getElementById("bulkMrButton");
    const bulkMrModal = document.getElementById("bulkMrModal");
    const closeBulkMrModal = document.getElementById("closeBulkMrModal");
    const bulkMrList = document.getElementById("bulkMrList");
    const bulkMrStatus = document.getElementById("bulkMrStatus");
    const bulkMrResults = document.getElementById("bulkMrResults");
    const selectAllMr = document.getElementById("selectAllMr");
    const submitBulkMr = document.getElementById("submitBulkMr");

    const STATUS_NOT_LIVE = "未上线";
    const STATUS_LIVE = "已上线";
    let currentPage = 1;
    const text = (value) => value == null || value === "" ? "-" : String(value);
    const escapeHtml = (value) => text(value)
      .replaceAll("&", "&amp;")
      .replaceAll("<", "&lt;")
      .replaceAll(">", "&gt;")
      .replaceAll('"', "&quot;")
      .replaceAll("'", "&#039;");
    const escapeAttr = (value) => String(value == null ? "" : value)
      .replaceAll("&", "&amp;")
      .replaceAll("<", "&lt;")
      .replaceAll(">", "&gt;")
      .replaceAll('"', "&quot;")
      .replaceAll("'", "&#039;");
    const key = (record) => [
      record.project,
      record.iteration_version,
      record.iteration_name,
      record.branch,
      record.feature_key,
      record.base_branch
    ].map(text).join(" ").toLowerCase();

    function option(value, label) {{
      const item = document.createElement("option");
      item.value = value;
      item.textContent = label;
      return item;
    }}

    function fillFilters() {{
      [...new Set(records.map((record) => record.project).filter(Boolean))]
        .sort()
        .forEach((value) => project.appendChild(option(value, value)));

      [...new Set(records.map((record) => record.iteration_version).filter(Boolean))]
        .sort((a, b) => a.localeCompare(b, undefined, {{ numeric: true }}))
        .forEach((value) => iteration.appendChild(option(value, value)));
    }}

    function formatDate(value) {{
      if (!value) return "-";
      const date = new Date(value);
      if (Number.isNaN(date.getTime())) return value;
      return date.toLocaleDateString("zh-CN", {{ month: "2-digit", day: "2-digit" }});
    }}

    async function apiJson(url, options = {{}}) {{
      const response = await fetch(url, options);
      const text = await response.text();
      let payload = null;
      try {{
        payload = text ? JSON.parse(text) : null;
      }} catch (_) {{
        payload = null;
      }}

      if (!response.ok) {{
        throw new Error(payload && payload.error ? payload.error : text || "请求失败");
      }}

      return payload;
    }}

    function setGitlabStatus(message, kind = "") {{
      gitlabStatus.textContent = message;
      gitlabStatus.className = kind ? `modal-status ${{kind}}` : "modal-status";
    }}

    function setBulkMrStatus(message, kind = "") {{
      bulkMrStatus.textContent = message;
      bulkMrStatus.className = kind ? `modal-status ${{kind}}` : "modal-status";
    }}

    function applyGitlabConfig(config) {{
      const gitlab = config.gitlab || {{}};
      gitlabUrl.value = gitlab.url || "";
      gitlabTarget.value = gitlab.default_target_branch || "main";
      gitlabToken.value = "";
      gitlabSavedToken.textContent = gitlab.has_token
        ? `已保存 Token：${{gitlab.token_masked}}。留空保存会继续使用它。`
        : "尚未保存 Token。";
    }}

    async function loadGitlabConfig() {{
      setGitlabStatus("正在读取配置...");
      const config = await apiJson("/api/config");
      applyGitlabConfig(config);
      setGitlabStatus("");
    }}

    function gitlabPayload() {{
      return {{
        url: gitlabUrl.value.trim(),
        token: gitlabToken.value.trim(),
        default_target_branch: gitlabTarget.value.trim() || "main"
      }};
    }}

    async function openGitlabSettings() {{
      gitlabModal.hidden = false;
      try {{
        await loadGitlabConfig();
      }} catch (error) {{
        setGitlabStatus(error.message, "error");
      }}
      gitlabUrl.focus();
    }}

    function closeGitlabSettings() {{
      gitlabModal.hidden = true;
      setGitlabStatus("");
    }}

    async function saveGitlabConfig() {{
      setGitlabStatus("正在保存...");
      try {{
        const result = await apiJson("/api/config", {{
          method: "POST",
          headers: {{ "Content-Type": "application/json" }},
          body: JSON.stringify(gitlabPayload())
        }});
        applyGitlabConfig(result);
        setGitlabStatus("已保存 GitLab 设置", "ok");
      }} catch (error) {{
        setGitlabStatus(error.message, "error");
      }}
    }}

    async function testGitlabConnection() {{
      setGitlabStatus("正在测试连接...");
      try {{
        const result = await apiJson("/api/gitlab/test", {{
          method: "POST",
          headers: {{ "Content-Type": "application/json" }},
          body: JSON.stringify(gitlabPayload())
        }});
        const name = result.name && result.username
          ? `${{result.name}} @${{result.username}}`
          : result.username || result.name || "当前用户";
        setGitlabStatus(`连接成功：${{name}}`, "ok");
      }} catch (error) {{
        setGitlabStatus(error.message, "error");
      }}
    }}

    function normalizedStatus(record) {{
      return record.status === STATUS_LIVE ? STATUS_LIVE : STATUS_NOT_LIVE;
    }}

    function statusRank(record) {{
      return normalizedStatus(record) === STATUS_NOT_LIVE ? 0 : 1;
    }}

    function compareRecords(a, b) {{
      const statusDiff = statusRank(a) - statusRank(b);
      if (statusDiff) return statusDiff;
      return text(b.created_at || b.branch_date).localeCompare(text(a.created_at || a.branch_date), undefined, {{ numeric: true }});
    }}

    function upsertRecord(updated, oldId = "") {{
      if (!updated || !updated._gc_id) return;
      const index = records.findIndex((record) => record._gc_id === (oldId || updated._gc_id));
      if (index >= 0) {{
        records[index] = updated;
      }} else {{
        records.push(updated);
      }}
    }}

    function removeRecord(id) {{
      records = records.filter((record) => record._gc_id !== id);
    }}

    function mrCandidates() {{
      return records.filter((record) => normalizedStatus(record) === STATUS_NOT_LIVE);
    }}

    function renderBulkMrList() {{
      const candidates = mrCandidates();
      bulkMrResults.innerHTML = "";
      bulkMrList.innerHTML = "";

      if (!candidates.length) {{
        bulkMrList.innerHTML = `<div class="empty">没有未上线记录</div>`;
        submitBulkMr.disabled = true;
        setBulkMrStatus("");
        return;
      }}

      submitBulkMr.disabled = false;
      setBulkMrStatus(`可选择 ${{candidates.length}} 条未上线记录`);
      for (const record of candidates) {{
        const item = document.createElement("label");
        item.className = "mr-item";
        item.innerHTML = `
          <input type="checkbox" value="${{escapeAttr(record._gc_id)}}" checked>
          <div>
            <div class="mr-item-title">
              <span>${{escapeHtml(record.project)}}</span>
              <span class="pill">${{escapeHtml(record.iteration_version)}}</span>
              <span>${{escapeHtml(record.iteration_name)}}</span>
            </div>
            <div class="mr-item-meta">${{escapeHtml(record.branch)}}</div>
          </div>
        `;
        bulkMrList.appendChild(item);
      }}
    }}

    function openBulkMrModal() {{
      bulkMrModal.hidden = false;
      renderBulkMrList();
    }}

    function closeBulkMrSettings() {{
      bulkMrModal.hidden = true;
      setBulkMrStatus("");
      bulkMrResults.innerHTML = "";
    }}

    function filteredRecords() {{
      const query = search.value.trim().toLowerCase();
      return records
        .filter((record) => {{
          if (project.value && record.project !== project.value) return false;
          if (iteration.value && record.iteration_version !== iteration.value) return false;
          if (statusFilter.value && normalizedStatus(record) !== statusFilter.value) return false;
          if (query && !key(record).includes(query)) return false;
          return true;
        }})
        .sort(compareRecords);
    }}

    function visiblePageNumbers(totalPages) {{
      const pages = new Set([1, totalPages]);
      for (let page = currentPage - 1; page <= currentPage + 1; page += 1) {{
        if (page >= 1 && page <= totalPages) pages.add(page);
      }}
      return [...pages].sort((a, b) => a - b);
    }}

    function renderPager(total, totalPages) {{
      pageTotal.textContent = `共 ${{total}} 条`;
      pager.innerHTML = "";

      const prev = document.createElement("button");
      prev.type = "button";
      prev.textContent = "上一页";
      prev.disabled = currentPage <= 1;
      prev.addEventListener("click", () => {{
        currentPage = Math.max(1, currentPage - 1);
        render();
      }});
      pager.appendChild(prev);

      let lastPage = 0;
      for (const page of visiblePageNumbers(totalPages)) {{
        if (page - lastPage > 1) {{
          const ellipsis = document.createElement("span");
          ellipsis.textContent = "...";
          pager.appendChild(ellipsis);
        }}
        const button = document.createElement("button");
        button.type = "button";
        button.textContent = String(page);
        button.className = page === currentPage ? "active" : "";
        button.addEventListener("click", () => {{
          currentPage = page;
          render();
        }});
        pager.appendChild(button);
        lastPage = page;
      }}

      const next = document.createElement("button");
      next.type = "button";
      next.textContent = "下一页";
      next.disabled = currentPage >= totalPages;
      next.addEventListener("click", () => {{
        currentPage = Math.min(totalPages, currentPage + 1);
        render();
      }});
      pager.appendChild(next);
    }}

    function render() {{
      const filtered = filteredRecords();
      const size = Number(pageSize.value || 10);
      const totalPages = Math.max(1, Math.ceil(filtered.length / size));
      currentPage = Math.min(Math.max(1, currentPage), totalPages);
      const start = (currentPage - 1) * size;
      const pageRecords = filtered.slice(start, start + size);

      rows.innerHTML = "";
      empty.hidden = filtered.length > 0;
      summary.innerHTML = `<span>显示 <strong>${{pageRecords.length}}</strong> / ${{filtered.length}} 条匹配记录，全部 ${{records.length}} 条</span>`;

      for (const record of pageRecords) {{
        const row = document.createElement("tr");
        const status = normalizedStatus(record);
        const statusClass = status === STATUS_LIVE ? "status-button is-live" : "status-button";
        const nextStatus = status === STATUS_LIVE ? STATUS_NOT_LIVE : STATUS_LIVE;
        row.innerHTML = `
          <td><span class="project-name">${{escapeHtml(record.project)}}</span></td>
          <td><span class="pill">${{escapeHtml(record.iteration_version)}}</span></td>
          <td>${{escapeHtml(record.iteration_name)}}</td>
          <td class="branch">${{escapeHtml(record.branch)}}</td>
          <td class="base-cell"><span class="base-pill">${{escapeHtml(record.base_branch)}}</span></td>
          <td class="muted date-cell">${{escapeHtml(formatDate(record.created_at || record.branch_date))}}</td>
          <td>
            <div class="actions">
              <button class="${{statusClass}}" type="button" data-status-id="${{escapeAttr(record._gc_id)}}" data-next-status="${{escapeAttr(nextStatus)}}">${{escapeHtml(status)}}</button>
              <button class="danger" type="button" data-delete="${{escapeAttr(record._gc_id)}}">删除</button>
            </div>
          </td>
        `;
        rows.appendChild(row);
      }}
      renderPager(filtered.length, totalPages);
    }}

    async function updateStatus(id, status) {{
      const response = await fetch("/api/status", {{
        method: "POST",
        headers: {{ "Content-Type": "application/json" }},
        body: JSON.stringify({{ id, status }})
      }});

      if (!response.ok) {{
        const message = await response.text();
        window.alert(message || "状态更新失败");
        return;
      }}

      const payload = await response.json();
      upsertRecord(payload.record, payload.old_id);
      render();
      if (!bulkMrModal.hidden) renderBulkMrList();
    }}

    async function submitBulkMergeRequests() {{
      const ids = Array.from(bulkMrList.querySelectorAll("input[type='checkbox']:checked"))
        .map((input) => input.value);
      if (!ids.length) {{
        setBulkMrStatus("请至少选择一条记录", "error");
        return;
      }}

      submitBulkMr.disabled = true;
      setBulkMrStatus(`正在提交 ${{ids.length}} 个 MR...`);
      bulkMrResults.innerHTML = "";

      const response = await fetch("/api/mrs", {{
        method: "POST",
        headers: {{ "Content-Type": "application/json" }},
        body: JSON.stringify({{ ids }})
      }});

      const textBody = await response.text();
      let payload = null;
      try {{
        payload = textBody ? JSON.parse(textBody) : null;
      }} catch (_) {{
        payload = null;
      }}

      if (!response.ok) {{
        setBulkMrStatus((payload && payload.error) || textBody || "批量创建 MR 失败", "error");
        submitBulkMr.disabled = false;
        return;
      }}

      const results = (payload && payload.results) || [];
      const okCount = results.filter((item) => item.ok).length;
      setBulkMrStatus(`完成：${{okCount}} / ${{results.length}} 个成功`, okCount === results.length ? "ok" : "error");
      bulkMrResults.innerHTML = results.map((item) => {{
        if (item.ok) {{
          upsertRecord(item.record, item.id);
          const label = item.created ? "已创建" : "已有";
          const link = item.web_url ? ` <a href="${{escapeAttr(item.web_url)}}" target="_blank" rel="noopener noreferrer">打开</a>` : "";
          return `<div class="mr-result ok">${{escapeHtml(label)}}：${{escapeHtml(item.project)}} / ${{escapeHtml(item.branch)}}${{link}}</div>`;
        }}
        return `<div class="mr-result error">失败：${{escapeHtml(item.error)}}</div>`;
      }}).join("");

      render();
      renderBulkMrList();
      if (okCount) {{
        setBulkMrStatus(`完成：${{okCount}} / ${{results.length}} 个成功，列表已更新`, okCount === results.length ? "ok" : "error");
      }}
      submitBulkMr.disabled = false;
    }}

    async function deleteRecord(id) {{
      const record = records.find((item) => item._gc_id === id);
      if (!record) return;
      const ok = window.confirm(`确认删除记录？\\n${{text(record.project)}} / ${{text(record.branch)}}`);
      if (!ok) return;

      const response = await fetch("/api/delete", {{
        method: "POST",
        headers: {{ "Content-Type": "application/json" }},
        body: JSON.stringify({{ id }})
      }});

      if (!response.ok) {{
        const message = await response.text();
        window.alert(message || "删除失败");
        return;
      }}

      removeRecord(id);
      render();
      if (!bulkMrModal.hidden) renderBulkMrList();
    }}

    fillFilters();
    render();
    const rerenderFromFirstPage = () => {{
      currentPage = 1;
      render();
    }};
    bulkMrButton.addEventListener("click", openBulkMrModal);
    closeBulkMrModal.addEventListener("click", closeBulkMrSettings);
    bulkMrModal.addEventListener("click", (event) => {{
      if (event.target === bulkMrModal) closeBulkMrSettings();
    }});
    selectAllMr.addEventListener("click", () => {{
      bulkMrList.querySelectorAll("input[type='checkbox']").forEach((input) => input.checked = true);
    }});
    submitBulkMr.addEventListener("click", submitBulkMergeRequests);
    gitlabSettings.addEventListener("click", openGitlabSettings);
    closeGitlabModal.addEventListener("click", closeGitlabSettings);
    gitlabModal.addEventListener("click", (event) => {{
      if (event.target === gitlabModal) closeGitlabSettings();
    }});
    saveGitlab.addEventListener("click", saveGitlabConfig);
    testGitlab.addEventListener("click", testGitlabConnection);
    [search, project, iteration, statusFilter].forEach((control) => control.addEventListener("input", rerenderFromFirstPage));
    pageSize.addEventListener("input", rerenderFromFirstPage);
    rows.addEventListener("click", (event) => {{
      const statusButton = event.target.closest("[data-status-id]");
      if (statusButton) {{
        updateStatus(statusButton.dataset.statusId, statusButton.dataset.nextStatus);
        return;
      }}

      const deleteButton = event.target.closest("[data-delete]");
      if (deleteButton) deleteRecord(deleteButton.dataset.delete);
    }});
    reset.addEventListener("click", () => {{
      search.value = "";
      project.value = "";
      iteration.value = "";
      statusFilter.value = "";
      rerenderFromFirstPage();
    }});
  </script>
</body>
</html>
"""


class GcWebHandler(http.server.BaseHTTPRequestHandler):
    ledger = DEFAULT_LEDGER
    config = DEFAULT_CONFIG
    project = None
    iteration = None

    def log_message(self, format, *args):
        return

    def send_text(self, status, content, content_type="text/plain; charset=utf-8"):
        body = content.encode("utf-8")
        self.send_response(status)
        self.send_header("Content-Type", content_type)
        self.send_header("Content-Length", str(len(body)))
        self.end_headers()
        self.wfile.write(body)

    def send_json(self, status, payload):
        self.send_text(status, json.dumps(payload, ensure_ascii=False), "application/json; charset=utf-8")

    def do_GET(self):
        route = urlparse(self.path).path
        if route == "/api/config":
            self.get_config()
            return

        if route not in ("/", "/index.html"):
            self.send_text(404, "Not found")
            return

        try:
            records, ledger_path = read_records(self.ledger)
            records = filter_indexed_records(
                list(enumerate(records)),
                project=self.project,
                iteration=self.iteration,
            )
            self.send_text(200, render_dashboard(records, ledger_path), "text/html; charset=utf-8")
        except ValueError as error:
            self.send_text(500, str(error))

    def do_POST(self):
        route = urlparse(self.path).path
        if route == "/api/config":
            self.save_config()
            return

        if route == "/api/gitlab/test":
            self.test_gitlab()
            return

        if route == "/api/mr":
            self.create_merge_request()
            return

        if route == "/api/mrs":
            self.create_merge_requests()
            return

        if route == "/api/status":
            self.update_status()
            return

        if route == "/api/delete":
            self.delete_record()
            return

        self.send_text(404, "Not found")

    def read_json_payload(self):
        content_length = int(self.headers.get("Content-Length", "0"))
        body = self.rfile.read(content_length).decode("utf-8")
        return json.loads(body)

    def get_config(self):
        try:
            config, _ = read_config(self.config)
            self.send_json(200, {"gitlab": public_gitlab_config(config)})
        except ValueError as error:
            self.send_text(500, str(error))

    def save_config(self):
        try:
            payload = self.read_json_payload()
            gitlab, path = save_gitlab_config(payload, self.config)
        except (KeyError, json.JSONDecodeError, ValueError) as error:
            self.send_text(400, f"保存失败：{error}")
            return

        self.send_json(200, {"saved": True, "path": str(path), "gitlab": gitlab})

    def test_gitlab(self):
        try:
            payload = self.read_json_payload()
            result = test_gitlab_connection(payload, self.config)
        except (KeyError, json.JSONDecodeError, RuntimeError, ValueError) as error:
            self.send_text(400, f"测试失败：{error}")
            return

        self.send_json(200, result)

    def create_merge_request(self):
        try:
            payload = self.read_json_payload()
            target_id = payload["id"]
            result = create_merge_request_for_record(self.ledger, target_id, self.config)
        except (KeyError, json.JSONDecodeError, RuntimeError, ValueError) as error:
            self.send_text(400, f"创建 MR 失败：{error}")
            return

        if result is None:
            self.send_text(404, "创建 MR 失败：记录不存在，页面可能需要刷新")
            return

        self.send_json(200, result)

    def create_merge_requests(self):
        try:
            payload = self.read_json_payload()
            target_ids = payload["ids"]
            if not isinstance(target_ids, list):
                raise ValueError("ids 必须是数组")
            result = create_merge_requests_for_records(self.ledger, target_ids, self.config)
        except (KeyError, json.JSONDecodeError, RuntimeError, ValueError) as error:
            self.send_text(400, f"批量创建 MR 失败：{error}")
            return

        self.send_json(200, {"results": result})

    def update_status(self):
        old_id = None
        try:
            payload = self.read_json_payload()
            target_id = payload["id"]
            old_id = target_id
            status = payload["status"]
            updated = update_record_status(self.ledger, target_id, status)
        except (KeyError, json.JSONDecodeError, ValueError) as error:
            self.send_text(400, f"状态更新失败：{error}")
            return

        if updated is None:
            self.send_text(404, "状态更新失败：记录不存在，页面可能需要刷新")
            return

        index, updated_record = updated
        record = dashboard_record(updated_record, index)
        self.send_json(200, {"updated": True, "old_id": old_id, "record": record})

    def delete_record(self):
        try:
            payload = self.read_json_payload()
            target_id = payload["id"]
            deleted = delete_record(self.ledger, target_id)
        except (KeyError, json.JSONDecodeError, ValueError) as error:
            self.send_text(400, f"删除失败：{error}")
            return

        if deleted is None:
            self.send_text(404, "删除失败：记录不存在，页面可能需要刷新")
            return

        self.send_json(200, {"deleted": True})

def find_available_port(host, start_port):
    for port in range(start_port, start_port + 50):
        with socket.socket(socket.AF_INET, socket.SOCK_STREAM) as probe:
            try:
                probe.bind((host, port))
            except OSError:
                continue
            return port
    raise RuntimeError(f"{host}:{start_port}-{start_port + 49} 都不可用")


def web_dashboard(args):
    handler = type(
        "ConfiguredGcWebHandler",
        (GcWebHandler,),
        {
            "ledger": args.ledger,
            "config": args.config,
            "project": args.project,
            "iteration": args.iteration,
        },
    )
    port = find_available_port(args.host, args.port)
    server = http.server.ThreadingHTTPServer((args.host, port), handler)
    url = f"http://{args.host}:{port}/"
    print(f"GC 可视化页面: {url}")
    print("按 Ctrl+C 停止服务")

    if not args.no_open:
        opened = webbrowser.open(url)
        if not opened:
            print("浏览器没有自动打开，可以手动打开上面的地址。")

    try:
        server.serve_forever()
    except KeyboardInterrupt:
        print("\n已停止 GC 可视化服务")
    finally:
        server.server_close()

    return 0


def add_ledger_argument(parser):
    parser.add_argument(
        "--ledger",
        default=DEFAULT_LEDGER,
        help=f"记录文件路径，默认 {DEFAULT_LEDGER}",
    )


def build_create_parser():
    parser = argparse.ArgumentParser(
        prog="gc",
        description="创建 Git 分支并记录项目、迭代版本、迭代名称和分支名。",
    )
    add_ledger_argument(parser)
    parser.add_argument("branch", help="要创建的分支名")
    parser.add_argument("-n", "--name", help="迭代名称，例如：同行账号监控")
    parser.add_argument("--dry-run", action="store_true", help="只预览，不创建分支或写记录")
    parser.set_defaults(func=create_branch)
    return parser


def build_list_parser():
    parser = argparse.ArgumentParser(
        prog="gc list",
        description="查看 gc 已记录的分支。",
    )
    add_ledger_argument(parser)
    parser.add_argument("--project", help="按项目名过滤")
    parser.add_argument("--iteration", help="按迭代版本或迭代名称过滤")
    parser.set_defaults(func=list_records)
    return parser


def build_rename_parser():
    parser = argparse.ArgumentParser(
        prog="gc rename",
        description="重命名 Git 分支并同步 gc 台账记录。",
    )
    add_ledger_argument(parser)
    parser.add_argument("new_branch", help="新的分支名")
    parser.add_argument("--from", dest="old_branch", help="要重命名的旧分支名，默认当前分支")
    parser.add_argument("-n", "--name", help="顺便更新迭代名称")
    parser.add_argument("--dry-run", action="store_true", help="只预览，不执行 Git 重命名")
    parser.set_defaults(func=rename_branch)
    return parser


def build_web_parser():
    parser = argparse.ArgumentParser(
        prog="gc web",
        description="启动 gc 分支记录可视化页面。",
    )
    add_ledger_argument(parser)
    parser.add_argument("--config", default=DEFAULT_CONFIG, help=f"配置文件路径，默认 {DEFAULT_CONFIG}")
    parser.add_argument("--host", default=DEFAULT_WEB_HOST, help=f"监听地址，默认 {DEFAULT_WEB_HOST}")
    parser.add_argument("--port", type=int, default=DEFAULT_WEB_PORT, help=f"起始端口，默认 {DEFAULT_WEB_PORT}")
    parser.add_argument("--project", help="只渲染指定项目")
    parser.add_argument("--iteration", help="只渲染指定迭代版本或迭代名称")
    parser.add_argument("--no-open", action="store_true", help="只启动服务，不自动打开浏览器")
    parser.set_defaults(func=web_dashboard)
    return parser


def main(argv=None):
    argv = list(sys.argv[1:] if argv is None else argv)

    try:
        if argv[:1] == ["list"]:
            parser = build_list_parser()
            args = parser.parse_args(argv[1:])
            return args.func(args)

        if argv[:1] == ["web"]:
            parser = build_web_parser()
            args = parser.parse_args(argv[1:])
            return args.func(args)

        if argv[:1] == ["rename"]:
            parser = build_rename_parser()
            args = parser.parse_args(argv[1:])
            return args.func(args)

        parser = build_create_parser()
        args = parser.parse_args(argv)

        if not args.name:
            parser.error("缺少迭代名称，请使用 -n，例如：gc ma-1.6.8-docFetch-5.20 -n 同行账号监控")

        return args.func(args)
    except (RuntimeError, ValueError) as error:
        print(f"gc: {error}", file=sys.stderr)
        return 1


if __name__ == "__main__":
    raise SystemExit(main())
