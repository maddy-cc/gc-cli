#!/usr/bin/env python3
import argparse
import hashlib
import html
import http.server
import json
import os
import re
import socket
import subprocess
import sys
from datetime import datetime, timezone
from pathlib import Path
from urllib.parse import quote, urlencode, urlparse
from urllib.request import Request, urlopen
from urllib.error import HTTPError, URLError
import webbrowser


DEFAULT_LEDGER = "~/.gc-branch-log.jsonl"
DEFAULT_CONFIG = "~/.gc-config.json"
DEFAULT_WEB_HOST = "127.0.0.1"
DEFAULT_WEB_PORT = 8765
STATUS_NOT_LIVE = "未上线"
STATUS_LIVE = "已上线"
VALID_STATUSES = {STATUS_NOT_LIVE, STATUS_LIVE}
VERSION_RE = re.compile(r"^\d+(?:\.\d+)+$")
DATE_RE = re.compile(r"^(?:\d{4}\.)?\d{1,2}\.\d{1,2}$")


def run_git(args, cwd=None, check=True):
    try:
        result = subprocess.run(
            ["git", *args],
            cwd=cwd,
            text=True,
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE,
        )
    except FileNotFoundError as error:
        if cwd and not Path(cwd).exists():
            raise RuntimeError(f"本地项目路径不存在: {cwd}") from error
        raise RuntimeError(str(error)) from error
    if check and result.returncode != 0:
        message = result.stderr.strip() or result.stdout.strip()
        raise RuntimeError(message)
    return result.stdout.strip()


def default_branch_date():
    now = datetime.now(timezone.utc).astimezone()
    return f"{now.month}.{now.day:02d}"


def is_version_part(value):
    return bool(VERSION_RE.match(value or ""))


def is_date_part(value):
    return bool(DATE_RE.match(value or ""))


def parse_branch_name(branch):
    parts = [part for part in branch.split("-") if part]
    if len(parts) < 2:
        raise ValueError(
            "分支名格式应类似 ma-1.6.8-docFetch-5.20 或 ma-virtualList-fix"
        )

    owner = parts[0]
    rest = parts[1:]
    iteration_version = ""
    branch_date = default_branch_date()

    if rest and is_version_part(rest[0]):
        iteration_version = rest.pop(0)

    if rest and is_date_part(rest[-1]):
        branch_date = rest.pop()

    feature_key = "-".join(rest)

    if not owner or not feature_key:
        raise ValueError("分支名至少需要包含姓名和功能，例如 ma-virtualList-fix")

    return {
        "owner": owner,
        "iteration_version": iteration_version,
        "feature_key": feature_key,
        "branch_date": branch_date,
    }


def get_repo_context():
    repo_root = Path(run_git(["rev-parse", "--show-toplevel"]))
    project_name = repo_root.name
    current_branch = run_git(["branch", "--show-current"], cwd=repo_root)
    head_sha = run_git(["rev-parse", "HEAD"], cwd=repo_root)

    if not current_branch:
        current_branch = "HEAD"

    return {
        "repo_root": str(repo_root),
        "project_name": project_name,
        "base_branch": current_branch,
        "base_sha": head_sha,
    }


def append_record(record, ledger_path):
    path = Path(os.path.expanduser(ledger_path))
    path.parent.mkdir(parents=True, exist_ok=True)
    with path.open("a", encoding="utf-8") as handle:
        handle.write(json.dumps(record, ensure_ascii=False, sort_keys=True) + "\n")
    return path


def resolve_config_path(path=DEFAULT_CONFIG):
    return Path(os.path.expanduser(path))


def read_config(path=DEFAULT_CONFIG):
    path = resolve_config_path(path)
    if not path.exists():
        return {}, path

    with path.open("r", encoding="utf-8") as handle:
        try:
            config = json.load(handle)
        except json.JSONDecodeError as error:
            raise ValueError(f"{path} 不是有效 JSON：{error}") from error

    if not isinstance(config, dict):
        raise ValueError(f"{path} 顶层必须是 JSON object")

    return config, path


def write_config(config, path=DEFAULT_CONFIG):
    path = resolve_config_path(path)
    path.parent.mkdir(parents=True, exist_ok=True)
    tmp_path = path.with_name(f"{path.name}.tmp")
    with tmp_path.open("w", encoding="utf-8") as handle:
        json.dump(config, handle, ensure_ascii=False, indent=2, sort_keys=True)
        handle.write("\n")
    os.chmod(tmp_path, 0o600)
    os.replace(tmp_path, path)
    os.chmod(path, 0o600)
    return path


def mask_token(token):
    if not token:
        return ""
    if len(token) <= 8:
        return "*" * len(token)
    return f"{token[:6]}...{token[-4:]}"


def public_gitlab_config(config):
    gitlab = config.get("gitlab", {})
    token = gitlab.get("token", "")
    return {
        "url": gitlab.get("url", ""),
        "default_target_branch": gitlab.get("default_target_branch", "main"),
        "has_token": bool(token),
        "token_masked": mask_token(token),
    }


def normalize_gitlab_url(url):
    url = (url or "").strip().rstrip("/")
    if not url:
        raise ValueError("请填写 GitLab 地址")
    parsed = urlparse(url)
    if parsed.scheme not in ("http", "https") or not parsed.netloc:
        raise ValueError("GitLab 地址应类似 https://gitlab.example.com")
    return url


def save_gitlab_config(payload, path=DEFAULT_CONFIG):
    config, _ = read_config(path)
    gitlab = dict(config.get("gitlab", {}))

    gitlab["url"] = normalize_gitlab_url(payload.get("url", gitlab.get("url", "")))
    target_branch = (payload.get("default_target_branch") or "main").strip()
    gitlab["default_target_branch"] = target_branch or "main"

    token = (payload.get("token") or "").strip()
    if token:
        gitlab["token"] = token
    elif not gitlab.get("token"):
        raise ValueError("首次保存需要填写 Access Token")

    config["gitlab"] = gitlab
    saved_path = write_config(config, path)
    return public_gitlab_config(config), saved_path


def resolve_gitlab_credentials(payload=None, path=DEFAULT_CONFIG):
    payload = payload or {}
    config, _ = read_config(path)
    gitlab = dict(config.get("gitlab", {}))

    url = normalize_gitlab_url(payload.get("url") or gitlab.get("url", ""))
    token = (payload.get("token") or gitlab.get("token", "")).strip()
    if not token:
        raise ValueError("请填写 Access Token")

    return url, token


def gitlab_api_json(url, token, path):
    return gitlab_api_request(url, token, path, method="GET")


def gitlab_api_request(url, token, path, method="GET", payload=None):
    body = None
    headers = {
        "PRIVATE-TOKEN": token,
        "Accept": "application/json",
        "User-Agent": "gc-branch-ledger",
    }
    if payload is not None:
        body = json.dumps(payload, ensure_ascii=False).encode("utf-8")
        headers["Content-Type"] = "application/json"

    request = Request(
        f"{url}{path}",
        data=body,
        headers=headers,
        method=method,
    )

    try:
        with urlopen(request, timeout=12) as response:
            body = response.read().decode("utf-8")
            return json.loads(body)
    except HTTPError as error:
        detail = error.read().decode("utf-8", errors="replace")
        raise RuntimeError(f"GitLab 返回 {error.code}: {detail[:240]}") from error
    except URLError as error:
        raise RuntimeError(f"无法连接 GitLab: {error.reason}") from error


def test_gitlab_connection(payload=None, path=DEFAULT_CONFIG):
    url, token = resolve_gitlab_credentials(payload, path)
    user = gitlab_api_json(url, token, "/api/v4/user")
    return {
        "ok": True,
        "url": url,
        "username": user.get("username") or user.get("name") or "",
        "name": user.get("name") or "",
    }


def normalize_remote_project_path(path):
    path = (path or "").strip().strip("/")
    if path.endswith(".git"):
        path = path[:-4]
    return path


def parse_gitlab_project_path(remote_url, gitlab_url):
    remote_url = (remote_url or "").strip()
    if not remote_url:
        raise ValueError("当前项目没有 origin remote")

    base = urlparse(gitlab_url)

    if "://" in remote_url:
        remote = urlparse(remote_url)
        remote_path = normalize_remote_project_path(remote.path)
        base_path = normalize_remote_project_path(base.path)
        if base_path and remote_path.startswith(f"{base_path}/"):
            remote_path = remote_path[len(base_path) + 1 :]
        return remote_path

    if ":" in remote_url and "@" in remote_url.split(":", 1)[0]:
        _, project_path = remote_url.split(":", 1)
        return normalize_remote_project_path(project_path)

    raise ValueError(f"无法解析 origin remote: {remote_url}")


def get_record_by_id(ledger_path, target_id):
    records, path = read_records(ledger_path)
    for index, record in enumerate(records):
        if record_id(record, index) == target_id:
            return records, path, index, record
    return records, path, None, None


def write_records(records, path):
    path.parent.mkdir(parents=True, exist_ok=True)
    tmp_path = path.with_name(f"{path.name}.tmp")
    with tmp_path.open("w", encoding="utf-8") as handle:
        for record in records:
            handle.write(json.dumps(record, ensure_ascii=False, sort_keys=True) + "\n")
    os.replace(tmp_path, path)


def get_origin_url(repo_root):
    if not repo_root:
        raise ValueError("这条记录缺少 repo_root，无法定位本地项目")
    return run_git(["remote", "get-url", "origin"], cwd=repo_root)


def get_gitlab_project(url, token, project_path, project_name=None):
    if project_path:
        encoded = quote(project_path, safe="")
        try:
            return gitlab_api_request(url, token, f"/api/v4/projects/{encoded}")
        except RuntimeError:
            pass

    if not project_name:
        raise RuntimeError(f"找不到 GitLab 项目: {project_path}")

    query = urlencode({"search": project_name, "membership": "true", "simple": "true", "per_page": "100"})
    projects = gitlab_api_request(url, token, f"/api/v4/projects?{query}")
    exact = [
        project
        for project in projects
        if project.get("path") == project_name or project.get("name") == project_name
    ]
    if len(exact) == 1:
        return exact[0]
    if len(exact) > 1:
        raise RuntimeError(f"GitLab 上找到多个同名项目 {project_name}，请检查 origin remote")
    raise RuntimeError(f"GitLab 上找不到项目 {project_name}")


def find_open_merge_request(url, token, project_id, source_branch):
    query = urlencode({"state": "opened", "source_branch": source_branch, "per_page": "20"})
    merge_requests = gitlab_api_request(url, token, f"/api/v4/projects/{project_id}/merge_requests?{query}")
    return merge_requests[0] if merge_requests else None


def remote_branch_exists(repo_root, branch):
    result = subprocess.run(
        ["git", "ls-remote", "--heads", "origin", branch],
        cwd=repo_root,
        text=True,
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
    )
    if result.returncode != 0:
        message = result.stderr.strip() or result.stdout.strip()
        raise RuntimeError(message)
    return bool(result.stdout.strip())


def build_merge_request_title(record):
    version = record.get("iteration_version") or ""
    name = record.get("iteration_name") or record.get("branch") or "Merge Request"
    return f"{version}-{name}" if version else name


def build_merge_request_description(record):
    lines = [
        f"项目：{record.get('project') or '-'}",
        f"分支：{record.get('branch') or '-'}",
        f"迭代版本：{record.get('iteration_version') or '-'}",
        f"迭代名称：{record.get('iteration_name') or '-'}",
        "",
        "由 gc branch ledger 自动创建。",
    ]
    return "\n".join(lines)


def create_merge_request_for_record(ledger_path, target_id, config_path=DEFAULT_CONFIG, mark_live=False):
    config, _ = read_config(config_path)
    url, token = resolve_gitlab_credentials(path=config_path)
    gitlab = config.get("gitlab", {})
    target_branch = gitlab.get("default_target_branch", "main")

    records, path, index, record = get_record_by_id(ledger_path, target_id)
    if record is None:
        return None

    branch = record.get("branch")
    repo_root = record.get("repo_root")
    if not branch:
        raise ValueError("这条记录缺少分支名")

    origin_url = get_origin_url(repo_root)
    project_path = parse_gitlab_project_path(origin_url, url)
    project = get_gitlab_project(url, token, project_path, record.get("project"))
    project_id = project["id"]

    if not remote_branch_exists(repo_root, branch):
        raise RuntimeError(f"远端 origin 上还没有分支 {branch}，请先 push 后再提 MR")

    existing = find_open_merge_request(url, token, project_id, branch)
    if existing:
        record["mr_url"] = existing.get("web_url")
        record["mr_iid"] = existing.get("iid")
        if mark_live:
            record["status"] = STATUS_LIVE
        records[index] = record
        write_records(records, path)
        return {"created": False, "merge_request": existing, "record": dashboard_record(record, index)}

    payload = {
        "source_branch": branch,
        "target_branch": target_branch,
        "title": build_merge_request_title(record),
        "description": build_merge_request_description(record),
        "remove_source_branch": False,
    }
    merge_request = gitlab_api_request(
        url,
        token,
        f"/api/v4/projects/{project_id}/merge_requests",
        method="POST",
        payload=payload,
    )
    record["mr_url"] = merge_request.get("web_url")
    record["mr_iid"] = merge_request.get("iid")
    if mark_live:
        record["status"] = STATUS_LIVE
    records[index] = record
    write_records(records, path)
    return {"created": True, "merge_request": merge_request, "record": dashboard_record(record, index)}


def create_merge_requests_for_records(ledger_path, target_ids, config_path=DEFAULT_CONFIG):
    results = []
    for target_id in target_ids:
        try:
            result = create_merge_request_for_record(
                ledger_path,
                target_id,
                config_path,
                mark_live=True,
            )
            if result is None:
                results.append({"id": target_id, "ok": False, "error": "记录不存在，页面可能需要刷新"})
                continue

            record = result.get("record", {})
            merge_request = result.get("merge_request", {})
            results.append(
                {
                    "id": target_id,
                    "ok": True,
                    "created": result.get("created", False),
                    "project": record.get("project"),
                    "branch": record.get("branch"),
                    "web_url": merge_request.get("web_url"),
                    "record": record,
                }
            )
        except (RuntimeError, ValueError) as error:
            results.append({"id": target_id, "ok": False, "error": str(error)})
    return results


def read_records(ledger_path):
    path = Path(os.path.expanduser(ledger_path))
    if not path.exists():
        return [], path

    records = []
    with path.open("r", encoding="utf-8") as handle:
        for line_number, line in enumerate(handle, start=1):
            line = line.strip()
            if not line:
                continue
            try:
                records.append(json.loads(line))
            except json.JSONDecodeError as error:
                raise ValueError(f"{path}:{line_number} 不是有效 JSON：{error}") from error
    return records, path


def filter_records(records, project=None, iteration=None):
    if project:
        records = [record for record in records if record.get("project") == project]

    if iteration:
        records = [
            record
            for record in records
            if record.get("iteration_version") == iteration
            or record.get("iteration_name") == iteration
        ]

    return records


def filter_indexed_records(indexed_records, project=None, iteration=None):
    records = indexed_records
    if project:
        records = [(index, record) for index, record in records if record.get("project") == project]

    if iteration:
        records = [
            (index, record)
            for index, record in records
            if record.get("iteration_version") == iteration
            or record.get("iteration_name") == iteration
        ]

    return records


def normalize_status(status):
    if status == STATUS_LIVE:
        return STATUS_LIVE
    return STATUS_NOT_LIVE


def record_id(record, index):
    payload = json.dumps(record, ensure_ascii=False, sort_keys=True)
    digest = hashlib.sha256(payload.encode("utf-8")).hexdigest()[:16]
    return f"{index}-{digest}"


def dashboard_record(record, index):
    return {
        "_gc_id": record_id(record, index),
        "base_branch": record.get("base_branch"),
        "branch": record.get("branch"),
        "branch_date": record.get("branch_date"),
        "created_at": record.get("created_at"),
        "feature_key": record.get("feature_key"),
        "iteration_name": record.get("iteration_name"),
        "iteration_version": record.get("iteration_version"),
        "mr_url": record.get("mr_url"),
        "project": record.get("project"),
        "status": normalize_status(record.get("status")),
    }


def delete_record(ledger_path, target_id):
    records, path = read_records(ledger_path)
    kept = []
    deleted = None

    for index, record in enumerate(records):
        if record_id(record, index) == target_id:
            deleted = record
            continue
        kept.append(record)

    if deleted is None:
        return None

    path.parent.mkdir(parents=True, exist_ok=True)
    tmp_path = path.with_name(f"{path.name}.tmp")
    with tmp_path.open("w", encoding="utf-8") as handle:
        for record in kept:
            handle.write(json.dumps(record, ensure_ascii=False, sort_keys=True) + "\n")
    os.replace(tmp_path, path)
    return deleted


def update_record_status(ledger_path, target_id, status):
    if status not in VALID_STATUSES:
        raise ValueError(f"状态只能是 {STATUS_NOT_LIVE} 或 {STATUS_LIVE}")

    records, path = read_records(ledger_path)
    updated = None
    updated_index = None

    for index, record in enumerate(records):
        if record_id(record, index) == target_id:
            record["status"] = status
            updated = record
            updated_index = index
            break

    if updated is None:
        return None

    path.parent.mkdir(parents=True, exist_ok=True)
    tmp_path = path.with_name(f"{path.name}.tmp")
    with tmp_path.open("w", encoding="utf-8") as handle:
        for record in records:
            handle.write(json.dumps(record, ensure_ascii=False, sort_keys=True) + "\n")
    os.replace(tmp_path, path)
    return updated_index, updated


def current_git_branch(repo_root):
    branch = run_git(["branch", "--show-current"], cwd=repo_root)
    if not branch:
        raise RuntimeError("当前处于 detached HEAD，无法判断要重命名的分支")
    return branch


def update_ledger_branch(ledger_path, repo_root, old_branch, new_branch, iteration_name=None):
    records, path = read_records(ledger_path)
    if not records:
        return 0, path

    branch_meta = parse_branch_name(new_branch)
    updated = 0
    repo_root = str(repo_root)

    for record in records:
        if record.get("branch") != old_branch:
            continue
        if record.get("repo_root") and record.get("repo_root") != repo_root:
            continue

        record["branch"] = new_branch
        record["iteration_version"] = branch_meta["iteration_version"]
        record["feature_key"] = branch_meta["feature_key"]
        record["branch_date"] = branch_meta["branch_date"]
        record["owner"] = branch_meta["owner"]
        if iteration_name:
            record["iteration_name"] = iteration_name
        updated += 1

    if updated:
        write_records(records, path)

    return updated, path


def rename_branch(args):
    branch_meta = parse_branch_name(args.new_branch)
    repo = get_repo_context()
    repo_root = repo["repo_root"]
    old_branch = args.old_branch or current_git_branch(repo_root)

    if old_branch == args.new_branch:
        raise ValueError("新旧分支名相同，不需要重命名")

    if args.dry_run:
        print("dry-run: 将执行以下操作")
        if args.old_branch:
            print(f"  git branch -m {old_branch} {args.new_branch}")
        else:
            print(f"  git branch -m {args.new_branch}")
    else:
        if args.old_branch:
            run_git(["branch", "-m", old_branch, args.new_branch], cwd=repo_root)
        else:
            run_git(["branch", "-m", args.new_branch], cwd=repo_root)

    updated, ledger_path = update_ledger_branch(
        args.ledger,
        repo_root,
        old_branch,
        args.new_branch,
        iteration_name=args.name,
    )

    print(f"已重命名分支: {old_branch} -> {args.new_branch}")
    print(f"迭代版本: {branch_meta['iteration_version'] or '-'}")
    print(f"功能: {branch_meta['feature_key']}")
    print(f"日期: {branch_meta['branch_date']}")
    if args.name:
        print(f"迭代名称: {args.name}")
    if updated:
        print(f"已同步台账记录: {updated} 条")
    else:
        print(f"未找到可同步的台账记录: {ledger_path}")
    print("提示: 如果旧分支已经 push 到远端，需要手动处理远端分支。")
    return 0


def create_branch(args):
    branch_meta = parse_branch_name(args.branch)
    repo = get_repo_context()

    if args.dry_run:
        print("dry-run: 将执行以下操作")
        print(f"  git checkout -b {args.branch}")
    else:
        run_git(["checkout", "-b", args.branch], cwd=repo["repo_root"])

    record = {
        "created_at": datetime.now(timezone.utc).astimezone().isoformat(timespec="seconds"),
        "project": repo["project_name"],
        "repo_root": repo["repo_root"],
        "base_branch": repo["base_branch"],
        "base_sha": repo["base_sha"],
        "branch": args.branch,
        "iteration_version": branch_meta["iteration_version"],
        "iteration_name": args.name,
        "feature_key": branch_meta["feature_key"],
        "branch_date": branch_meta["branch_date"],
        "owner": branch_meta["owner"],
        "status": STATUS_NOT_LIVE,
    }

    if args.dry_run:
        print("dry-run: 将记录以下内容")
        print(json.dumps(record, ensure_ascii=False, indent=2, sort_keys=True))
        return 0

    ledger = append_record(record, args.ledger)

    print(f"已创建分支: {args.branch}")
    print(f"项目: {record['project']}")
    print(f"迭代版本: {record['iteration_version']}")
    print(f"迭代名称: {record['iteration_name']}")
    print(f"记录文件: {ledger}")
    return 0


def list_records(args):
    records, path = read_records(args.ledger)
    if not records:
        print(f"还没有记录: {path}")
        return 0

    records = filter_records(records, project=args.project, iteration=args.iteration)

    if not records:
        print("没有匹配记录")
        return 0

    for record in records:
        print(
            f"{record.get('project')} | {record.get('iteration_version')} | "
            f"{record.get('iteration_name')} | {record.get('branch')}"
        )
    return 0


def render_dashboard(indexed_records, ledger_path):
    if indexed_records and not isinstance(indexed_records[0], tuple):
        indexed_records = list(enumerate(indexed_records))

    records = [record for _, record in indexed_records]
    view_records = [dashboard_record(record, index) for index, record in indexed_records]
    data = json.dumps(view_records, ensure_ascii=False).replace("</", "<\\/")
    generated_at = datetime.now(timezone.utc).astimezone().isoformat(timespec="seconds")
    total = len(records)
    projects = len({record.get("project", "") for record in records if record.get("project")})
    iterations = len(
